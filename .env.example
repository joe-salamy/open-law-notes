# Vast.ai Cloud GPU API Configuration
# Copy this file to .env and fill in your actual values

# Vast.ai API URL (get this from Vast.ai console after deployment)
VAST_API_URL=http://your-vast-instance:port/transcribe

# Vast.ai API Key (REQUIRED for authentication)
VAST_API_KEY=your-api-key-here

# HuggingFace Token (REQUIRED for speaker diarization)
# Get token from: https://huggingface.co/settings/tokens (read access)
# Accept pyannote license: https://huggingface.co/pyannote/speaker-diarization-3.1
HF_TOKEN=
