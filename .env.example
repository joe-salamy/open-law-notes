# Salad Cloud GPU API Configuration
# Copy this file to .env and fill in your actual values

# Salad API URL (get this from Salad portal after deployment)
SALAD_API_URL=https://your-deployment.salad.cloud/transcribe

# Salad API Key (REQUIRED for authentication)
SALAD_API_KEY=your-api-key-here

# HuggingFace Token (REQUIRED for speaker diarization)
# Get token from: https://huggingface.co/settings/tokens (read access)
# Accept pyannote license: https://huggingface.co/pyannote/speaker-diarization-3.1
HF_TOKEN=
